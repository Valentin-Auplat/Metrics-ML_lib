p1 <- ggplot(scree_df, aes(x = Composante, y = Variance)) +
geom_col() +
xlab("Composante") + ylab("Variance expliquée") +
ggtitle("Scree plot - Iris")
cum_df <- data.frame(Composante = seq_along(variance_cumulee),
Cumulee    = variance_cumulee)
p2 <- ggplot(cum_df, aes(x = Composante, y = Cumulee)) +
geom_point() + geom_line() +
geom_hline(yintercept = 0.95, color = "red", linetype = "dashed") +  # axhline 95%
xlab("Nombre de composantes") + ylab("Variance cumulée") +
ggtitle("Variance cumulée - Iris")
combined_plot <- grid.arrange(p1, p2, ncol = 2)
ggsave(file.path(output_path, "pca_variance_iris.png"),
plot = combined_plot, width = 14, height = 5)
# ===== Bloc 10 : projection 2D colorée par la cible (PC1 vs PC2) =====
# MODIFICATION : 3 classes au lieu de 2 -> on définit 3 couleurs au lieu de
# "Décédés"/"Survivants" en rouge/vert. Les labels viennent directement des
# niveaux du facteur Species (pas besoin de les recoder comme pour le Titanic).
species_colors <- c(setosa = "red", versicolor = "green", virginica = "blue")
plot_df_2d <- data.frame(PC1 = X_pca_full$PC1,
PC2 = X_pca_full$PC2,
target = y)   # y est déjà le facteur Species, pas besoin de relabel
var1_pct <- round(variance_expliquee[1] * 100, 1)
var2_pct <- round(variance_expliquee[2] * 100, 1)
p_2d <- ggplot(plot_df_2d, aes(x = PC1, y = PC2, color = target)) +
geom_point(alpha = 0.6) +
scale_color_manual(values = species_colors) +
xlab(paste0("PC1 (", var1_pct, "% var)")) +
ylab(paste0("PC2 (", var2_pct, "% var)")) +
ggtitle("Projection sur les 2 premières composantes principales - Iris")
p_2d
ggsave(file.path(output_path, "pca_projection_2d_iris.png"), plot = p_2d,
width = 10, height = 7)
# ===== Bloc 11 : projection 2D (PC1 vs PC3) =====
var3_pct <- round(variance_expliquee[3] * 100, 1)
plot_df_pc13 <- data.frame(PC1 = X_pca_full$PC1,
PC3 = X_pca_full$PC3,
target = y)
p_2d_pc13 <- ggplot(plot_df_pc13, aes(x = PC1, y = PC3, color = target)) +
geom_point(alpha = 0.6) +
scale_color_manual(values = species_colors) +
xlab(paste0("PC1 (", var1_pct, "% var)")) +
ylab(paste0("PC3 (", var3_pct, "% var)")) +
ggtitle("Projection sur les composantes principales 1 et 3 - Iris")
p_2d_pc13
ggsave(file.path(output_path, "pca_projection_2d_PC1_PC3_iris.png"),
plot = p_2d_pc13, width = 10, height = 7)
cat("\n=== Fichiers générés ===\n")
cat("CSV: pca_variance_expliquee_iris.csv, pca_loadings_iris.csv, pca_projected_iris.csv\n")
cat("Figures: pca_variance_iris.png, pca_projection_2d_iris.png, pca_projection_2d_PC1_PC3_iris.png\n")
# ===== Bloc 12 : plot 3D statique =====
# mpl_toolkits.mplot3d Axes3D -> scatterplot3d::scatterplot3d() en R
# (package conçu spécifiquement pour reproduire ce type de scatter 3D statique)
# MODIFICATION : 3 couleurs (une par espèce) au lieu du test binaire y_reset == 0
couleurs <- species_colors[as.character(y)]
png(file.path(output_path, "pca_projection_3d_iris.png"),
width = 12, height = 9, units = "in", res = 150)
s3d <- scatterplot3d(
x = X_pca_full$PC1,
y = X_pca_full$PC3,
z = X_pca_full$PC2,   # PC2 sur l'axe z, comme dans le code Python
color = couleurs,
pch = 19,
xlab = paste0("PC1 (", var1_pct, "%)"),
ylab = paste0("PC3 (", var3_pct, "%)"),
zlab = paste0("PC2 (", round(variance_expliquee[2]*100,1), "%)"),
main = "Projection 3D - PC1, PC2, PC3 - Iris"
)
legend("topright", legend = names(species_colors),
col = species_colors, pch = 19)
dev.off()
# ===== Bloc 13 : plot 3D interactif (plotly) =====
# plotly.express px.scatter_3d -> plotly::plot_ly() en R, même moteur sous-jacent
plot_df_3d <- data.frame(
PC1 = X_pca_full$PC1,
PC2 = X_pca_full$PC2,
PC3 = X_pca_full$PC3,
Species = y   # facteur à 3 niveaux directement, pas besoin de relabel
)
fig_3d <- plot_ly(
plot_df_3d,
x = ~PC1, y = ~PC3, z = ~PC2,
color = ~Species,
colors = species_colors,   # MODIFICATION : 3 couleurs nommées au lieu de 2
type = "scatter3d",
mode = "markers",
marker = list(size = 4, opacity = 0.6)
) %>%
layout(
title = "Projection PCA 3D - Iris",
scene = list(
xaxis = list(title = paste0("PC1 (", var1_pct, "%)")),
yaxis = list(title = paste0("PC3 (", var3_pct, "%)")),
zaxis = list(title = paste0("PC2 (", round(variance_expliquee[2]*100,1), "%)"))
)
)
#fig.write_html(...) -> htmlwidgets::saveWidget()
htmlwidgets::saveWidget(fig_3d,
file.path(output_path, "pca_projection_3d_iris.html"))
#fig.show() -> print(fig_3d) #ouvre le widget dans le viewer RStudio
print(fig_3d)
